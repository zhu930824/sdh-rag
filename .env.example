# 环境变量配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 数据库配置 ====================
DB_USERNAME=rag_user
DB_PASSWORD=rag_password
DB_PORT=3306

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Elasticsearch 配置 ====================
ES_PORT=9200
ES_PORT_NODE=9300

# ==================== 后端服务配置 ====================
BACKEND_PORT=8989

# ==================== 前端服务配置 ====================
FRONTEND_PORT=80

# ==================== AI 服务配置 ====================
# 通义千问 API 密钥（必填）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== JWT 配置 ====================
# JWT 管理员密钥（建议修改为随机字符串）
JWT_ADMIN_SECRET=your_admin_secret_key_here_256_bits_required
# JWT 用户密钥（建议修改为随机字符串）
JWT_USER_SECRET=your_user_secret_key_here_256_bits_required

# ==================== 可选配置 ====================
# WebSearch API 密钥（可选）
WEBSEARCH_API_KEY=

# 阿里云 OSS 配置（可选）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=
